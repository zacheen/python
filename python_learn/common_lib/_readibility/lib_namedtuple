from collections import namedtuple
# able to access variables like class, but easier to create 

Point = namedtuple('Point' , ['x' , 'y'])
Point = namedtuple('Point' , ('x' , 'y'))

p = Point(3, 4)

# access
print(p.x)          # 3
print(p.y)          # 4
print(p[0])         # 3
print(p[1])         # 4
print(p)

